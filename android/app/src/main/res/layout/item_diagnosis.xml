<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="4dp"
    app:cardBackgroundColor="#0D1B2A"
    app:cardCornerRadius="10dp"
    app:cardElevation="1dp"
    app:strokeColor="#1E3A4D"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="14dp">

        <!-- ICD-10 code badge -->
        <TextView
            android:id="@+id/textIcdCode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            android:textColor="#3B82F6"
            android:textSize="12sp"
            android:textStyle="bold"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:layout_marginEnd="12dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/textDiagnosisText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#E0E6ED"
                android:textSize="14sp"
                android:ellipsize="end"
                android:maxLines="2" />

            <!-- Confidence bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="6dp">

                <ProgressBar
                    android:id="@+id/progressConfidence"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="0dp"
                    android:layout_height="6dp"
                    android:layout_weight="1"
                    android:max="100"
                    android:progressTint="#16A34A"
                    android:progressBackgroundTint="#1E3A4D" />

                <TextView
                    android:id="@+id/textConfidence"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:textColor="#8899AA"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Negated badge (hidden by default) -->
        <TextView
            android:id="@+id/badgeNegated"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NEGATED"
            android:textColor="#DC2626"
            android:textSize="10sp"
            android:textStyle="bold"
            android:paddingHorizontal="8dp"
            android:paddingVertical="3dp"
            android:layout_marginStart="8dp"
            android:visibility="gone" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
