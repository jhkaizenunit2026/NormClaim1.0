# NormClaim — copy to `.env` in this directory and fill in values.
# Never commit `.env` (it is gitignored).

# Required for AI extraction (Google AI Studio / Gemini)
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Required — Supabase PostgreSQL for persistent storage.
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# Required public values for browser + server runtime config.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Optional compatibility alias used by some modules.
# SUPABASE_URL should match NEXT_PUBLIC_SUPABASE_URL when set.
SUPABASE_URL=https://your-project-ref.supabase.co

# Required server-only value. Never expose in browser bundles.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Optional compatibility alias for extraction pipeline scripts.
# GOOGLE_API_KEY should match GEMINI_API_KEY when set.
# GOOGLE_API_KEY=your_gemini_api_key_here

# Optional — Java HAPI FHIR service. If unreachable, FHIR uses a local Python fallback.
FHIR_SERVICE_URL=http://localhost:8001/fhir/bundle

# Optional — if true, returns test-data/cached_extraction.json when present (same document_id injected; skips Gemini).
USE_DEMO_CACHE=false
